<?xml version="1.0" encoding="UTF-8"?>
<infinispan xmlns="urn:infinispan:config:16.0">

    <jgroups>
        <stack-file name="jgroupsStack" path="configuration/local/jgroups-tcp.xml"/>
    </jgroups>

    <cache-container name="default">
        <transport stack="jgroupsStack" lock-timeout="600000" cluster="default" />
        <jmx enabled="true">
            <property name="enabled">true</property>
        </jmx>
    </cache-container>
</infinispan>
